PORT=5000
NODE_ENV=development
MONGODB_URI=YOUR_MONGODB_CONNECTION_STRING
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
CLOUDINARY_CLOUD_NAME=CLOUD_NAME_HERE
CLOUDINARY_API_KEY=API_KEY_HERE
CLOUDINARY_API_SECRET=CLOUDINARY_API_SECRET_HERE
GEMINI_API_KEY=GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-1.5-flash
RUN_AGGREGATOR_ON_STARTUP=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=USER_EMAIL_HERE
EMAIL_PASS=App_password_here
CLIENT_URL=http://localhost:5173
